# Copy to .env and fill in the channel(s) you want. Leave the rest blank.
# (Locally: `export $(grep -v '^#' .env | xargs)` then `python -m src.main`.
#  In GitHub Actions: add these as repository Secrets instead of a file.)

# --- Phone push via ntfy.sh (easiest: free, no account) --------------------
# 1) Install the "ntfy" app, 2) subscribe to a topic name only you know.
NTFY_TOPIC=
# NTFY_SERVER=https://ntfy.sh   # only if self-hosting ntfy

# --- Email (SMTP) ----------------------------------------------------------
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=          # Gmail: create an App Password

# --- Discord ---------------------------------------------------------------
DISCORD_WEBHOOK_URL=

# Where to persist alert state (so you only get pinged on changes).
STATE_FILE=state/state.json
